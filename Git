Setting untuk git

# Config awal
git config --global user.name "Nama Kamu" 
git config --global user.email "email@kamu.com" 

# Untuk menclone sebuah repo
git clone https://github.com/username/nama-repo.git => 

# Lihat perubahan yang ada
git status

# Tambahkan file ke staging
git add nama-file.txt
# atau tambahkan semua file
git add .

# Simpan perubahan dengan pesan
git commit -m "Pesan commit kamu"

# Kirim ke GitHub
git push

# Jika ada perubahan terbaru di GitHub, tarik ke komputer:
git pull

# Lihat branch yang ada
git branch

# Buat branch baru
git branch nama-branch

# Pindah ke branch itu
git checkout nama-branch

# Buat sekaligus pindah (lebih praktis)
git checkout -b nama-branch

# Pastikan kamu di branch tujuan (misalnya main)
git checkout main

# Gabungkan branch lain ke sini
git merge nama-branch

